# --- Configuration ---
CANDIDATES = ["Alice", "Bob", "Charlie"]
voters = []  # List to store voter dictionaries

# --- Validation Functions ---
def get_valid_age():
    while True:
        age_input = input("Enter Voter Age (18-120): ").strip()
        if not age_input:
            print("Error: Input cannot be empty.")
        elif not age_input.isdigit():
            print("Error: Age must be a valid integer.")
        else:
            age = int(age_input)
            if 18 <= age <= 120:
                return age
            else:
                print("Error: Age must be between 18 and 120.")

def get_valid_candidate():
    print(f"Available Candidates: {', '.join(CANDIDATES)}")
    while True:
        # .title() ensures 'alice' becomes 'Alice' to match the list
        choice = input("Enter Candidate Name: ").strip().title()
        if not choice:
            print("Error: Input cannot be empty.")
        elif choice in CANDIDATES:
            return choice
        else:
            print("Error: Invalid candidate. Please check spelling.")

def get_valid_id():
    while True:
        v_id = input("Enter Voter ID (Alphanumeric): ").strip()
        if not v_id:
            print("Error: Input cannot be empty.")
        elif not v_id.isalnum():
            print("Error: ID must be alphanumeric (letters/numbers only).")
        else:
            # Check for Duplicate ID
            is_duplicate = False
            for voter in voters:
                if voter['id'] == v_id:
                    is_duplicate = True
                    break
            
            if is_duplicate:
                print("Error: This Voter ID has already been registered.")
            else:
                return v_id

# --- Menu Functions ---
def register_voter():
    print("\n--- New Voter Registration ---")
    # Get validated inputs
    age = get_valid_age()
    choice = get_valid_candidate()
    v_id = get_valid_id()
    
    # Create dictionary and store it
    voter_data = {
        "id": v_id,
        "age": age,
        "choice": choice
    }
    voters.append(voter_data)
    print(f"Success: Voter {v_id} registered.")

def display_voters():
    print("\n--- All Registered Voters ---")
    if not voters:
        print("No records found.")
    else:
        print(f"{'ID':<15} {'Age':<10} {'Choice':<15}")
