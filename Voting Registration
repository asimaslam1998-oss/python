# A list to store dictionary objects for each voter
voters = []

# Valid candidates tuple (or list)
CANDIDATES = ["Josh","AJ","Bernie"]
def get_valid_age():
    while True:
        age_input = input("Enter Voter Age (18-120): ").strip()
        
        # Check if empty
        if not age_input:
            print("Error: Age cannot be empty.")
            continue
            
        # Check if integer
        if not age_input.isdigit():
            print("Error: Age must be a number.")
            continue
            
        age = int(age_input)
        
        # Check range
        if 18 <= age <= 120:
            return age
        else:
            print("Error: Age must be between 18 and 120.")
def get_valid_candidate():
    # Show options to user
    print(f"Candidates: {', '.join(CANDIDATES)}")
    
    while True:
        choice = input("Enter Candidate Name: ").strip().capitalize()
        
        if not choice:
            print("Error: Choice cannot be empty.")
            continue
            
        if choice in CANDIDATES:
            return choice
        else:
            print("Error: Invalid candidate. Please choose Josh, AJ, or Bernie.")
def get_valid_id():
    while True:
        v_id = input("Enter Voter ID (Alphanumeric): ").strip()
        
        if not v_id:
            print("Error: ID cannot be empty.")
            continue
            
        if v_id.isalnum():
            # Optional: Check for uniqueness
            id_exists = any(voter['id'] == v_id for voter in voters)
            if id_exists:
                print("Error: This ID has already voted.")
            else:
                return v_id
        else:
            print("Error: ID must contain only letters and numbers.")
