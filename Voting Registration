# --- Main Program Loop ---
def main():
    while True:
        print("\n=== VOTING SYSTEM MENU ===")
        print("1. Register New Voter")
        print("2. Display All Registered Voters")
        print("3. Search for a Voter by ID")
        print("4. Exit")
        
        selection = input("Select an option (1-4): ").strip()
        
        if selection == '1':
            register_voter()
        elif selection == '2':
            display_voters()
        elif selection == '3':
            search_voter()
